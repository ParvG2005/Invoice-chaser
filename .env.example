# See docs/ENVIRONMENT.md for full details on each variable (owner, where to get it, which env it lives in).
# All values below are blank placeholders — never commit real secrets here.

# --- Database (Supabase project "Invoice Chaser") ---
DATABASE_URL=       # Prisma pooled connection string (port 6543)
DIRECT_URL=         # Prisma direct connection string, used for migrations (port 5432)

# --- Auth (Clerk) ---
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# --- Skip-login demo (interviewer preview) ---
# Email of a shared Clerk account. When set, the landing page shows a
# "View live demo" button that auto-signs interviewers in as this account.
# The account must sign in once (to create its User+Org), then run
# `npm run db:seed:demo` to populate data. Real email/reminder sends are
# BLOCKED for this account's org. Leave blank to disable demo mode.
DEMO_CLERK_USER_EMAIL=
# Optional: pin the demo org id explicitly. If blank it's resolved from the
# demo user's email → membership.
DEMO_ORGANIZATION_ID=

# --- AI email drafting ---
GROQ_API_KEY=
GROQ_MODEL=         # e.g. llama-3.3-70b-versatile
GEMINI_API_KEY=
GEMINI_MODEL=       # e.g. gemini-2.0-flash

# --- Legacy email (Nodemailer/SMTP) ---
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SMTP_FROM_EMAIL=

# --- Legacy/fallback WhatsApp ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=
CALLMEBOT_API_KEY=

# --- Rate limiting ---
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- Background jobs (Inngest) ---
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# --- Email (Resend) ---
RESEND_API_KEY=
RESEND_FROM_EMAIL=
RESEND_WEBHOOK_SECRET=

# --- WhatsApp Cloud API (Meta) ---
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_WEBHOOK_VERIFY_TOKEN=

# --- AI assistant ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-5
ASSISTANT_KILL_SWITCH=   # set to "true" to disable all assistant tool execution

# --- Observability ---
SENTRY_DSN=
SENTRY_AUTH_TOKEN=
