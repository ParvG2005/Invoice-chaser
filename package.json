{
  "name": "invoicepilot",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=26"
  },
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "pages-build": "prisma generate && prisma migrate deploy && npx opennextjs-cloudflare build",
    "format": "prettier --write \"src/**/*.{ts,tsx,json,css}\"",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "db:backfill-parties": "tsx --env-file=.env scripts/backfill-parties.ts",
    "db:seed:e2e": "tsx --env-file-if-exists=.env prisma/seed-e2e.ts",
    "db:seed:analytics": "tsx --env-file-if-exists=.env scripts/seed-analytics-fixture.ts",
    "postinstall": "prisma generate",
    "cf:preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "cf:deploy": "opennextjs-cloudflare build && opennextjs-cloudflare deploy"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.110.0",
    "@clerk/nextjs": "^7.5.12",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@radix-ui/react-dialog": "^1.1.6",
    "@radix-ui/react-dropdown-menu": "^2.1.6",
    "@radix-ui/react-label": "^2.1.2",
    "@radix-ui/react-select": "^2.1.6",
    "@radix-ui/react-slot": "^1.1.2",
    "@radix-ui/react-switch": "^1.1.3",
    "@radix-ui/react-tabs": "^1.1.3",
    "@tanstack/react-query": "^5.101.2",
    "@tanstack/react-table": "^8.21.3",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.38.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "fast-xml-parser": "^5.9.3",
    "inngest": "^4.11.0",
    "lucide-react": "^0.477.0",
    "next": "16.2.10",
    "next-themes": "^0.4.4",
    "nodemailer": "^8.0.7",
    "papaparse": "^5.5.2",
    "pg": "^8.22.0",
    "radix-ui": "^1.6.1",
    "react": "19.2.7",
    "react-day-picker": "^10.0.1",
    "react-dom": "19.2.7",
    "recharts": "^2.15.1",
    "resend": "^4.1.2",
    "sonner": "^2.0.1",
    "tailwind-merge": "^3.0.2",
    "zod": "^4.4.3",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@clerk/testing": "^2.2.2",
    "@opennextjs/cloudflare": "^1.20.1",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4.3.2",
    "@types/node": "^26.1.0",
    "@types/nodemailer": "^8.0.0",
    "@types/papaparse": "^5.3.15",
    "@types/pg": "^8.20.0",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "dotenv": "^17.4.2",
    "eslint": "^9",
    "eslint-config-next": "^16.2.10",
    "eslint-config-prettier": "^10.0.2",
    "jsdom": "^29.1.1",
    "prettier": "^3.5.3",
    "prisma": "^7.8.0",
    "tailwindcss": "^4.3.2",
    "tsx": "^4.19.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9",
    "wrangler": "^4.107.0"
  },
  "overrides": {
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3"
  }
}
